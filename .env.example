# ── Translation model ──────────────────────────────────────────────────────
# Translates subtitle cues. In cinematic mode, also receives per-cue frames.
# Good translators: large multilingual LLMs.
#   Cloud: claude-opus-4-7, claude-sonnet-4-6, gpt-4o, gpt-4o-mini, gemini-1.5-pro
#   Open-source — chinese-strong: qwen2.5:72b, deepseek-v3, glm-4-flash
#   Open-source — general: llama3.1:70b, mistral-large
BABEL_TRANSLATION_LLM_TYPE=anthropic
BABEL_TRANSLATION_LLM_MODEL=claude-opus-4-7
BABEL_TRANSLATION_LLM_ENDPOINT=https://api.openai.com/v1
BABEL_TRANSLATION_LLM_API_KEY=sk-ant-...
# Required for cinematic mode. Anthropic always supports vision.
BABEL_TRANSLATION_LLM_SUPPORTS_VISION=true

# ── Vision model ───────────────────────────────────────────────────────────
# Describes scene keyframes (1-2 sentence per shot). Used by scene + cinematic.
# Good vision describers: strong OCR + scene understanding.
#   Cloud: claude-opus-4-7, gpt-4o, gemini-1.5-pro
#   Open-source — chinese-strong: qwen2.5-vl:72b, qwen2.5-vl:7b, glm-4v-plus, internvl2:26b
#   Open-source — general: llava:34b, llava-1.6:34b, minicpm-v:8b, pixtral-12b
BABEL_VISION_LLM_TYPE=anthropic
BABEL_VISION_LLM_MODEL=claude-opus-4-7
BABEL_VISION_LLM_ENDPOINT=https://api.openai.com/v1
# Paste the same value as BABEL_TRANSLATION_LLM_API_KEY if both slots use the same provider.
BABEL_VISION_LLM_API_KEY=sk-ant-...
# Master switch — toggle off if you don't have a vision LLM. Disables scene/cinematic.
BABEL_VISION_LLM_ENABLED=true

# Optional: DeepL API key (free tier: 500k chars/month).
# Free-tier keys end in ":fx" — the app auto-detects free vs paid endpoint.
DEEPL_API_KEY=

# Emby integration. Used by the app to resolve item IDs to disk paths,
# list items missing target-lang subs, and trigger metadata refresh after a
# .vtt is written. Generate the API key in Emby → Settings → Advanced → API Keys.
EMBY_URL=http://emby:8096
EMBY_API_KEY=

# Optional shared secret for the /webhook/emby endpoint. If set, requests to
# the webhook must include `X-Babel-Token: <this value>` in their headers.
# Configure the matching header in Emby's webhook notification.
WEBHOOK_SECRET=

# Required when using the GHCR `image:` line in docker-compose.yml.
# Set this to the GitHub username or org that owns the published images.
GHCR_OWNER=

# Container runtime user. Default is the image's `app` user (UID/GID 568,
# matching TrueNAS Scale's apps user). Override if your host uses a different
# UID — e.g. PUID=1000 PGID=1000 on vanilla Ubuntu. Set both to 0 for root.
PUID=568
PGID=568

# Render group GID on the HOST (for iGPU passthrough). Find with:
#   getent group render | cut -d: -f3
RENDER_GID=107

# Image flavor when pulling from GHCR: cpu | openvino
IMAGE_FLAVOR=openvino

# Whisper backend: cpu (faster-whisper) | openvino (Intel iGPU)
BABEL_WHISPER_BACKEND=openvino
BABEL_WHISPER_MODEL=small
BABEL_OPENVINO_DEVICE=GPU

BABEL_CLAUDE_MODEL=claude-opus-4-7
